# Base URL of a TEI-compatible embedding service (POST /embed).
EMBED_URL=http://localhost:8080

# Prepended to every query before embedding. Must match the training-time
# query template (e.g. "query: " for E5-family models).
QUERY_PREFIX="query: "

# Milvus connection. The collection is expected to store the display fields
# (name, manufacturerName, ean, article_number) so the playground can read
# them as `output_fields` on the search call.
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=offers

# Pagination.
PAGE_SIZE=50
SEARCH_TOP_K=100

# Directory containing data_*.parquet shards of the unlabeled queries dataset.
# Distinct query_term values are loaded into memory at startup and used by
# the "Random query" button.
# QUERIES_PARQUET_DIR=/mnt/HC_Volume_105463954/simplesystem/data/queries_offers_unlabeled.parquet

# HTTP Basic Auth. If PLAYGROUND_PASSWORD is unset or empty, the app runs open.
# PLAYGROUND_USER=admin
# PLAYGROUND_PASSWORD=

# Reference embed server (reference_embed_server/main.py) only:
# CHECKPOINT=checkpoints/useful-cub-58/best-step=4880-val_full_catalog_ndcg_at_5=0.7379.ckpt
# DEVICE=auto

# Sentence-transformers export served by the TEI container in compose.yaml.
# Produce with `scripts/export_for_tei.py`. Defaults to the path baked into
# compose.yaml if unset.
# TEI_MODEL_DIR=/mnt/HC_Volume_105463954/simplesystem/models/useful-cub-58-st
