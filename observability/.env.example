# Caddy basic-auth credentials gating Grafana behind the cloudflared tunnel.
# Generate the hash with:
#   docker run --rm caddy:2.8 caddy hash-password --plaintext 'YOUR_PASSWORD'
# Each '$' in the resulting bcrypt hash MUST be doubled to '$$' in this file
# so docker compose's variable interpolation does not eat parts of it.
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=$$2a$$14$$replace_me_with_doubled_dollar_hash
