Seed set to 42
model:
  model_name: deepset/gelectra-large
  head_dropout: 0.1
  label_smoothing: 0.0
  focal_gamma: 2.0
  use_class_weights: false
  gradient_checkpointing: false
  compile: true
data:
  path: ../data/queries_offers_esci/queries_offers_merged_labeled.parquet
  positive_label: Exact
  split_column: split
  column_mapping:
    query_id: query_id
    offer_id: offer_id
    query_term: query_term
    name: name
    manufacturer_name: manufacturer_name
    manufacturer_article_number: manufacturer_article_number
    manufacturer_article_type: manufacturer_article_type
    article_number: article_number
    ean: ean
    category_paths: category_paths
    description: description
    label: label
  batch_size: 32
  num_workers: 8
  pin_memory: true
  max_pair_length: 512
  val_fraction: 0.05
  clean_html: true
  limit_rows: null
  column_rename: null
  features:
    enabled: false
    slot_order:
    - ean
    - article
    - spec
    normalize:
      leading_zeros: keep
      multivalue_separators: ',;|'
    ean:
      enabled: true
      offer_field: ean
      validate: gtin
      on_offer_invalid: none
    article:
      enabled: true
      offer_fields:
      - article_number
      - manufacturer_article_number
      min_token_len: 4
    spec:
      enabled: false
      offer_fields:
      - name
      - description
      rules:
      - thread_m
      - g_thread
      - dimensions
      - fraction
      - decimal_de
      - mm
      - cm
      - micrometre
      - cross_sect
      - inch_zoll
      - voltage
      - ampere
      - ah
      - watt
      - hz
      - volume_l
      - mass_kg
      - pressure
      - din
      - iso
      - en_norm
      - strength_cls
      - stainless
      - ral_color
      - ip_rating
      - cat_rating
      - dn_nw_pn
      - pg_gland
      - awg
      - lumen_lux
      on_offer_invalid: none
  query_template: '{{ query_term }}'
  offer_template: 'Artikel: {{ name }}

    {% if ean %} EAN: {{ ean }}{% endif %}

    {% if article_number %} Artikelnummer: {{ article_number }}{% endif %}

    {% if manufacturer_article_number %} Herstellernummer: {{ manufacturer_article_number
    }}{% endif %}

    {% if category_text %} Kategorie: {{ category_text }}{% endif %}

    {% if manufacturer_article_type %} Artikeltyp: {{ manufacturer_article_type }}{%
    endif %}

    {% if manufacturer_name %} Marke: {{ manufacturer_name }}{% endif %}

    {% if clean_description %} Beschreibung: {{ clean_description }}{% endif %}'
trainer:
  accelerator: auto
  devices: 1
  max_epochs: 1
  max_time: null
  precision: bf16-mixed
  log_every_n_steps: 10
  accumulate_grad_batches: 1
  deterministic: false
  limit_train_batches: 1.0
  limit_val_batches: 1.0
  val_check_interval: 1.0
  checkpoint_dir: checkpoints
  enable_checkpointing: true
  resume_from_checkpoint: null
  monitor_metric: val/cls/micro_f1
  monitor_mode: max
  validate_before_training: false
optimizer:
  lr: 1.5e-05
  weight_decay: 0.01
  scheduler: constant_with_warmup
  warmup_ratio: 0.33
  warmup_steps: null
  override_lr_on_resume: false
logger:
  tracking_uri: http://127.0.0.1:5001
  experiment_name: simplesystem-embedding
  run_name: 01-baseline-naive-retrain-1ep
  log_model: false
  tags:
    project: embedding-train
seed: 42
